echo "=== 1️⃣ Route not found (API Gateway / Lambda) ==="
echo "Error:"
echo "Invoke-RestMethod : {\"message\":\"Route not found\"}"
echo "Cause:"
echo "- Lambda was using event.resource instead of event.rawPath"
echo "- HTTP method check mismatch"
echo "Fix:"
echo "- Use event.rawPath for routes"
echo "- Match HTTP method (GET for /Products, POST for /Orders)"

echo ""
echo "=== 2️⃣ Internal Server Error (500) on POST /Orders ==="
echo "Error:"
echo "Invoke-RestMethod : {\"message\":\"Internal Server Error\"}"
echo "Cause:"
echo "- Lambda failed because payload format was wrong or headers missing"
echo "- POST body sent as ['1'] instead of [{id:'1', quantity:1}]"
echo "Fix:"
echo "- Send JSON body: { items: [{ id: '1', quantity: 1 }] }"
echo "- Add Content-Type: application/json header"

echo ""
echo "=== 3️⃣ CORS error in browser ==="
echo "Error:"
echo "Access to fetch at 'https://.../Orders' from origin 'https://my-mini-store-123.s3...'"
echo "has been blocked by CORS policy"
echo "Cause:"
echo "- Browser requires OPTIONS preflight request for POST with JSON"
echo "- API Gateway CORS headers missing or incomplete"
echo "- Lambda response missing Access-Control-Allow-Origin"
echo "Fix:"
echo "- API Gateway: Allow-Origin: *, Methods: GET,POST,OPTIONS, Headers: *"
echo "- Lambda: Add OPTIONS handler returning 200 with headers"
echo "- Lambda: Include Access-Control-Allow-Origin in all responses"

echo ""
echo "=== 4️⃣ Preflight OPTIONS blocked ==="
echo "Symptom:"
echo "- POST request fails before reaching Lambda"
echo "- Network tab shows OPTIONS request failed"
echo "Cause:"
echo "- No handler for OPTIONS method in Lambda"
echo "Fix:"
echo "if (method === 'OPTIONS') { return 200 with CORS headers }"

echo ""
echo "=== 5️⃣ Missing Access-Control-Allow-Headers ==="
echo "Error:"
echo "- 'No headers are allowed' in API Gateway CORS"
echo "Cause:"
echo "- Browser sends Content-Type header with POST"
echo "- API Gateway rejects request because headers not allowed"
echo "Fix:"
echo "- Set Access-Control-Allow-Headers: * (or include Content-Type)"

echo ""
echo "=== 6️⃣ favicon.ico 403 Forbidden ==="
echo "Error:"
echo "GET https://my-mini-store-123.s3.../favicon.ico 403"
echo "Cause:"
echo "- Browser automatically requests favicon.ico from S3"
echo "- Object does not exist"
echo "Fix:"
echo "- Optional: Ignore error"
echo "- Or upload a favicon.ico to S3 bucket"

echo ""
echo "=== 7️⃣ Browser caching old index.html ==="
echo "Symptom:"
echo "- Changes to index.html not reflected after upload"
echo "Cause:"
echo "- Browser cached old version"
echo "Fix:"
echo "- Hard refresh: Ctrl+Shift+R (Windows) or Command+Shift+R (Mac)"
echo "- Optionally clear cache or open in Incognito mode"

echo ""
echo "=== 8️⃣ Button click not triggering order ==="
echo "Symptom:"
echo "- Clicking 'Place Order' does nothing"
echo "Cause:"
echo "- Function name mismatch or JS error"
echo "- CORS preventing fetch from completing"
echo "Fix:"
echo "- Ensure <button onclick='order()'> matches function order()"
echo "- Use DevTools → Console & Network to debug"
echo "- Fix CORS headers in Lambda/API Gateway"

echo ""
echo "=== 9️⃣ Hard-to-debug differences between PowerShell vs Browser ==="
echo "Symptom:"
echo "- POST /Orders works in PowerShell but fails in browser"
echo "Cause:"
echo "- PowerShell ignores CORS, browser enforces it"
echo "Fix:"
echo "- Always test frontend in browser"
echo "- Implement proper CORS headers and OPTIONS preflight"

echo ""
echo "=== ✅ Summary ==="
echo "- Always check route, method, payload format"
echo "- Always add CORS headers (Lambda + API Gateway)"
echo "- Handle OPTIONS preflight"
echo "- Hard refresh after S3 updates"
echo "- Use DevTools for debugging requests/errors"

